{
  "name": "regiverse",
  "private": true,
  "scripts": {
    "frontend": "npm start --prefix regiverse-frontend",
    "backend": "npm run dev --prefix regiverse-backend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "build": "npm install --prefix regiverse-frontend && npm run build --prefix regiverse-frontend"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "postcss-nesting": "^14.0.0",
    "qrcode": "^1.5.4",
    "resend": "^6.12.3",
    "socket.io-client": "^4.8.3",
    "twilio": "^6.0.2",
    "xlsx": "^0.18.5"
  }
}
